/* =========================================================
   AirAware – Global Styles
   ========================================================= */

/* Dark theme (default) */
:root {
    --bg-primary: #0f1923;
    --bg-secondary: #1a2732;
    --bg-card: #1e2d3d;
    --text-primary: #e8edf2;
    --text-secondary: #8899a6;
    --accent: #1da1f2;
    --accent-hover: #1a91da;
    --good: #2ecc71;
    --moderate: #f1c40f;
    --unhealthy: #e67e22;
    --very-unhealthy: #e74c3c;
    --hazardous: #8e44ad;
    --border: #2c3e50;
    --shadow: rgba(0, 0, 0, 0.3);
    --radius: 12px;
}

/* Light theme */
[data-theme="light"] {
    --bg-primary: #f0f2f5;
    --bg-secondary: #ffffff;
    --bg-card: #ffffff;
    --text-primary: #1a1a2e;
    --text-secondary: #555770;
    --accent: #0d8ecf;
    --accent-hover: #0b7ab8;
    --border: #d1d9e0;
    --shadow: rgba(0, 0, 0, 0.08);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg-primary);
    color: var(--text-primary);
    min-height: 100vh;
}

a { color: var(--accent); text-decoration: none; }
a:hover { color: var(--accent-hover); }

/* ---- Navbar ---- */
.navbar {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    height: 60px;
    position: sticky;
    top: 0;
    z-index: 1000;
}
.navbar .logo {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
    margin-right: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
}
.navbar .logo span { font-size: 1.6rem; }
.navbar nav { display: flex; gap: 0.25rem; }
.navbar nav a {
    color: var(--text-secondary);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.2s;
}
.navbar nav a:hover,
.navbar nav a.active {
    color: var(--text-primary);
    background: var(--bg-card);
}
.navbar .nav-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 1rem;
}
.navbar .city-select {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

/* ---- Theme Toggle ---- */
.theme-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    user-select: none;
}
.theme-toggle .toggle-icon {
    font-size: 1.1rem;
    transition: opacity 0.2s;
}
.theme-toggle .toggle-track {
    width: 40px;
    height: 22px;
    background: var(--border);
    border-radius: 11px;
    position: relative;
    transition: background 0.3s;
}
.theme-toggle .toggle-track .toggle-thumb {
    width: 18px;
    height: 18px;
    background: var(--text-primary);
    border-radius: 50%;
    position: absolute;
    top: 2px;
    left: 2px;
    transition: transform 0.3s;
}
[data-theme="light"] .theme-toggle .toggle-track {
    background: var(--accent);
}
[data-theme="light"] .theme-toggle .toggle-track .toggle-thumb {
    transform: translateX(18px);
}
.navbar select {
    background: var(--bg-card);
    color: var(--text-primary);
    border: 1px solid var(--border);
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    font-size: 0.9rem;
    cursor: pointer;
}

/* ---- Container ---- */
.container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.5rem;
}

/* ---- Cards ---- */
.card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: 0 4px 12px var(--shadow);
}
.card h2 {
    font-size: 1rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
}
.card .value {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.1;
}
.card .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-top: 0.5rem;
}

/* ---- Grid layouts ---- */
.grid-top {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}
.grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}
.grid-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}

/* ---- AQI big display ---- */
.aqi-display {
    text-align: center;
    padding: 2rem;
}
.aqi-display .value {
    font-size: 4.5rem;
}
.aqi-display .city-name {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
}

/* ---- Prediction cards ---- */
.prediction-card {
    text-align: center;
}
.prediction-card .time-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
}
.prediction-card .value {
    font-size: 2.5rem;
}

/* ---- Pollutant grid ---- */
.pollutant-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}
.pollutant-item {
    text-align: center;
    padding: 0.75rem;
    background: var(--bg-secondary);
    border-radius: 8px;
}
.pollutant-item .label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-bottom: 0.25rem;
}
.pollutant-item .val {
    font-size: 1.3rem;
    font-weight: 600;
}
.pollutant-item .unit {
    font-size: 0.7rem;
    color: var(--text-secondary);
}

/* ---- Advisory ---- */
.advisory-list {
    list-style: none;
    padding: 0;
}
.advisory-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
}
.advisory-list li:last-child { border-bottom: none; }
.advisory-list li::before {
    content: "⚠";
    font-size: 1rem;
}
.advisory-list.vulnerable li::before {
    content: "🔴";
}

/* ---- Vulnerable Groups ---- */
.vulnerable-section {
    margin-top: 1.5rem;
}
.vulnerable-toggles {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
}
.vulnerable-toggles label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    padding: 0.4rem 0.8rem;
    background: var(--bg-secondary);
    border-radius: 8px;
    border: 1px solid var(--border);
    font-size: 0.9rem;
    transition: all 0.2s;
}
.vulnerable-toggles label:hover {
    border-color: var(--accent);
}
.vulnerable-toggles input:checked + span {
    color: var(--accent);
    font-weight: 600;
}
.vulnerable-toggles input { display: none; }

.vulnerable-alert {
    background: rgba(231, 76, 60, 0.1);
    border: 1px solid var(--very-unhealthy);
    border-radius: 8px;
    padding: 1rem;
    margin-top: 0.75rem;
}
.vulnerable-alert h4 {
    color: var(--very-unhealthy);
    margin-bottom: 0.5rem;
    text-transform: capitalize;
}

/* ---- Charts ---- */
.chart-container {
    position: relative;
    height: 300px;
    width: 100%;
}
.chart-container canvas {
    width: 100% !important;
    height: 100% !important;
}

/* ---- Map ---- */
#map {
    height: 500px;
    border-radius: var(--radius);
    z-index: 1;
}
.map-legend {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
}
.legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
}
.legend-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
}

/* ---- Weather strip ---- */
.weather-strip {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    padding: 0.5rem 0;
}
.weather-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

/* ---- Loading ---- */
.loading {
    text-align: center;
    padding: 3rem;
    color: var(--text-secondary);
}
.source-tag {
    display: inline-block;
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 600;
    letter-spacing: 0.03em;
}
.source-tag.live { background: rgba(46,204,113,0.2); color: #2ecc71; }
.source-tag.cached { background: rgba(241,196,15,0.2); color: #f1c40f; }
.spinner {
    display: inline-block;
    width: 30px;
    height: 30px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-bottom: 0.75rem;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ---- Tabs (trends page) ---- */
.tabs {
    display: flex;
    gap: 0.25rem;
    margin-bottom: 1.5rem;
}
.tab-btn {
    background: var(--bg-card);
    color: var(--text-secondary);
    border: 1px solid var(--border);
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s;
}
.tab-btn:hover, .tab-btn.active {
    color: var(--text-primary);
    background: var(--accent);
    border-color: var(--accent);
}

/* ---- Landing Page – Hero ---- */
.hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 60px);
    background: radial-gradient(ellipse at 50% 0%, rgba(29,161,242,0.15) 0%, transparent 70%),
                var(--bg-primary);
    text-align: center;
    padding: 3rem 1.5rem;
}
.hero-content {
    max-width: 700px;
}
.hero-logo {
    font-size: 5rem;
    margin-bottom: 1rem;
    animation: float 3s ease-in-out infinite;
}
@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}
.hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--accent), #6dd5fa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
}
.hero-tagline {
    font-size: 1.25rem;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-weight: 500;
}
.hero-sub {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
}
.hero-cta {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    padding: 0.85rem 2.5rem;
    border-radius: 30px;
    font-size: 1.1rem;
    font-weight: 600;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(29,161,242,0.35);
}
.hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 28px rgba(29,161,242,0.5);
    color: #fff;
}

/* ---- Landing Page – Features ---- */
.features-section {
    padding: 4rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
}
.section-title {
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 2.5rem;
    color: var(--text-primary);
}
.features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
}
.feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 1.5rem;
    text-align: center;
    transition: transform 0.2s, box-shadow 0.2s;
}
.feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px var(--shadow);
}
.feature-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
}
.feature-card h3 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
    color: var(--accent);
}
.feature-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
}

/* ---- Landing Page – Footer ---- */
.landing-footer {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    border-top: 1px solid var(--border);
    margin-top: 2rem;
}

/* ---- Weather label ---- */
.weather-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

/* ---- Responsive ---- */
@media (max-width: 900px) {
    .grid-top { grid-template-columns: 1fr; }
    .grid-2, .grid-3 { grid-template-columns: 1fr; }
    .pollutant-grid { grid-template-columns: repeat(2, 1fr); }
    .features-grid { grid-template-columns: 1fr 1fr; }
    .hero-title { font-size: 2.5rem; }
}
@media (max-width: 600px) {
    .navbar { padding: 0 1rem; }
    .navbar nav { gap: 0; }
    .container { padding: 1rem; }
    .pollutant-grid { grid-template-columns: 1fr 1fr; }
    .features-grid { grid-template-columns: 1fr; }
    .hero-title { font-size: 2rem; }
    .hero-logo { font-size: 3.5rem; }
}
